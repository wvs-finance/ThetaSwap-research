+## Wraps the pd.diff or methods used for getting teh time series that
+## calcultes L_{t+1} - L_{t}, it places on the first cell the average
 
 def delta(series:TimeSeries) -> TimeSeries:
+    """
+    Wraps pd.diff to calculate L_{t+1} - L_{t} for a time series.
+    Places the average of the series in the first cell.
+    """
     diff = series.diff()
     return diff.fillna({diff.index[0]: series.mean()})
 
 
+## Wraps the function from pandas to get the time series from the
+## division of the values at each timestamp
+
 def div(numerator: TimeSeries, denominator: TimeSeries) -> TimeSeries:
+    """
+    Wraps element-wise division of two time series at each timestamp.
+    """
     return numerator / denominator
 
 
+## Wraps the forward looking feature meaning
+## reference value_{t+1} instead of value_t on a time series
+
 def forward(series: TimeSeries) -> TimeSeries:
+    """
+    Wraps forward looking feature - references value_{t+1} instead of value_t.
+    """
     return series.shift(-1)
 
 def lagged(series: TimeSeries) -> TimeSeries:
+    """
+    Wraps lagged feature - references value_{t-1} instead of value_t.
+    """
     return series.shift(1)
 
