+
 def variance(series: TimeSeries, libraryPointer:Optional[str]) -> TimeSeries:
+    """
+    Wraps a variance method from a library on a time series.
+    Returns cumulative variance at each timestamp (TimeSeries), not a single float.
+    Uses strategy pattern to look for the class or function.
+    """
     strategy = VarianceStrategy()
     return strategy(series, libraryPointer)
 
